// Prisma schema - J.A Construções E-commerce
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

enum PedidoStatus {
  pendente
  pago
  entregue
  cancelado
}

model Usuario {
  id         String   @id @default(cuid())
  email      String   @unique
  senhaHash  String
  nome       String?
  role       Role     @default(admin)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Categoria {
  id        String      @id @default(cuid())
  nome      String
  slug      String      @unique
  parentId  String?
  parent    Categoria?  @relation("Subcategorias", fields: [parentId], references: [id], onDelete: SetNull)
  filhos    Categoria[] @relation("Subcategorias")
  produtos  Produto[]

  @@index([parentId])
}

model Produto {
  id          String          @id @default(cuid())
  nome        String
  slug        String          @unique
  descricao   String?
  preco       Decimal         @db.Decimal(10, 2)
  estoque     Int             @default(0)
  imagens     ProdutoImagem[]
  ativo       Boolean         @default(true)
  destaque    Boolean         @default(false)
  categoriaId String
  categoria   Categoria       @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  itensPedido ItemPedido[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([categoriaId])
  @@index([slug])
  @@index([ativo])
  @@index([destaque])
}

/// URLs públicas (ex.: Cloudflare R2); ordem define a sequência na vitrine.
model ProdutoImagem {
  id        String  @id @default(cuid())
  url       String
  ordem     Int     @default(0)
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([produtoId])
}

model Pedido {
  id                String        @id @default(cuid())
  clienteNome       String
  clienteEmail      String
  clienteTelefone   String?
  endereco          String
  total             Decimal       @db.Decimal(10, 2)
  status            PedidoStatus  @default(pendente)
  stripeSessionId   String?       @unique
  itens             ItemPedido[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model ItemPedido {
  id            String   @id @default(cuid())
  pedidoId      String
  pedido        Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId     String
  produto       Produto  @relation(fields: [produtoId], references: [id], onDelete: Restrict)
  quantidade    Int
  precoUnitario Decimal  @db.Decimal(10, 2)

  @@index([pedidoId])
}
