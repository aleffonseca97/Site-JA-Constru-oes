# Database (PostgreSQL) — obrigatório para Prisma CLI e runtime (adapter pg)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable"
# Após clonar o repositório: npm run db:generate (client em ./generated/prisma, pasta ignorada pelo git)

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Cloudflare R2 (S3-compatible) — imagens de produtos
# URL pública do bucket (domínio r2.dev ou customizado), sem barra no final
R2_PUBLIC_URL="https://your-bucket.r2.dev"
NEXT_PUBLIC_R2_PUBLIC_URL="https://your-bucket.r2.dev"
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"
